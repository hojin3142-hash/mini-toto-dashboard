# Streamlit Community Cloud 배포 시 사용할 시크릿 템플릿입니다.
# 실제 값은 GitHub에 올리지 말고, Streamlit Cloud 앱 설정의
# "Secrets" 메뉴(Settings > Secrets)에 아래 형식 그대로 붙여넣으세요.
#
# 로컬에서 테스트하려면 이 파일을 복사해 .streamlit/secrets.toml 로 저장하세요.
# (.streamlit/secrets.toml 은 .gitignore 에 의해 커밋되지 않습니다.)

LDAS_POSTGRES_HOST = "여기에_DB_호스트"
LDAS_POSTGRES_PORT = "여기에_DB_포트"
LDAS_POSTGRES_DATABASE = "여기에_DB_이름"
LDAS_POSTGRES_USER = "여기에_DB_유저"
LDAS_POSTGRES_PASSWORD = "여기에_DB_비밀번호"
GEMINI_API_KEY = "여기에_API_키"
